# General
COMPOSE_PROJECT_NAME=sqstorage
TZ=Europe/Berlin

# Ports exposed on the Raspberry Pi host
SQSTORAGE_HTTP_PORT=8080
PHPMYADMIN_HTTP_PORT=8081

# sqStorage runtime
USE_REGISTRATION=false
USE_PRETTY_URLS=false
SQSTORAGE_ENABLE_INSTALLER=true
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=32M
PHP_POST_MAX_SIZE=32M
PHP_MAX_EXECUTION_TIME=120

# Database connection used by sqStorage
DB_HOST=db
DB_PORT=3306
DB_NAME=sqstorage
DB_USER=sqstorage
DB_PASSWORD=change-me-app-password

# MariaDB bootstrap
MARIADB_ROOT_PASSWORD=change-me-root-password
MARIADB_ROOT_HOST=%
MARIADB_DATABASE=${DB_NAME}
MARIADB_USER=${DB_USER}
MARIADB_PASSWORD=${DB_PASSWORD}

# phpMyAdmin
PMA_HOST=${DB_HOST}
PMA_PORT=${DB_PORT}
PMA_ADMIN_USER=sqstorage_admin
PMA_ADMIN_PASSWORD=change-me-pma-admin-password
PMA_USER=${PMA_ADMIN_USER}
PMA_PASSWORD=${PMA_ADMIN_PASSWORD}
PMA_ARBITRARY=0
PMA_ABSOLUTE_URI=

# Backups
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * 0
BACKUP_RETENTION_DAYS=90
BACKUP_FILENAME_PREFIX=sqstorage
BACKUP_DIR=/backups
BACKUP_HOST_DIR=/opt/sqstorage/backups
